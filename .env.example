PORT=8080
ALLOWED_ORIGIN=*

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MODEL_TITLE=gpt-4.1-mini
OPENAI_MODEL_ANALYZE=gpt-4.1
OPENAI_MODEL_INTERPRET=gpt-4.1
OPENAI_MODEL_UPDATE_SOUL=gpt-4.1

# Supabase JWT verification (required unless REQUIRE_AUTH=false)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Set REQUIRE_AUTH=false ONLY for local dev / smoke tests
# REQUIRE_AUTH=true

# Rate limits (per minute)
GLOBAL_RATE_LIMIT_PER_MIN=120
AI_RATE_LIMIT_PER_MIN=20

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_YEARLY=price_...
APP_BASE_URL=http://localhost:5173
# Optional custom redirects
# STRIPE_SUCCESS_URL=http://localhost:5173/profile/subscription?checkout=success
# STRIPE_CANCEL_URL=http://localhost:5173/profile/subscription?checkout=cancelled
# STRIPE_PORTAL_RETURN_URL=http://localhost:5173/profile/subscription
