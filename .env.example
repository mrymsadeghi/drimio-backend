PORT=8080
ALLOWED_ORIGIN=*

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MODEL_TITLE=gpt-4.1-mini
OPENAI_MODEL_ANALYZE=gpt-4.1
OPENAI_MODEL_INTERPRET=gpt-4.1
OPENAI_MODEL_UPDATE_SOUL=gpt-4.1

# Supabase JWT verification (required unless REQUIRE_AUTH=false)
SUPABASE_URL=https://your-project.supabase.co
# Set REQUIRE_AUTH=false ONLY for local dev / smoke tests
# REQUIRE_AUTH=true

# Rate limits (per minute)
GLOBAL_RATE_LIMIT_PER_MIN=120
AI_RATE_LIMIT_PER_MIN=20
